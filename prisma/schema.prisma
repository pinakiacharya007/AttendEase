generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model University {
  id         Int      @id @default(autoincrement())
  name       String
  shortName  String
  themeColor String   @default("#635bff")
  address    String?
  website    String?
  isSetup    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("universities")
}

model Department {
  id             Int            @id @default(autoincrement())
  name           String
  code           String         @unique
  programmeType  ProgrammeType  @default(UG)
  totalYears     Int            @default(3)
  rollPrefix     String
  examRollPrefix String
  hodId          Int?           @unique
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  academicYears  AcademicYear[]
  hod            User?          @relation("DeptHOD", fields: [hodId], references: [id])
  holidays       Holiday[]
  semesters      Semester[]
  students       Student[]
  subjects       Subject[]
  users          User[]         @relation("DeptUsers")

  @@map("departments")
}

model User {
  id               Int            @id @default(autoincrement())
  name             String
  email            String?        @unique
  username         String         @unique
  passwordHash     String
  role             UserRole       @default(TEACHER)
  deptId           Int?
  phone            String?
  isActive         Boolean        @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  aiLogs           AiLog[]
  attendanceMarked Attendance[]
  hodOfDept        Department?    @relation("DeptHOD")
  notifications    Notification[]
  subjectsTaught   Subject[]
  department       Department?    @relation("DeptUsers", fields: [deptId], references: [id])

  @@map("users")
}

model AcademicYear {
  id         Int        @id @default(autoincrement())
  deptId     Int
  label      String
  startDate  DateTime
  endDate    DateTime
  isCurrent  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)
  semesters  Semester[]

  @@unique([deptId, label])
  @@map("academic_years")
}

model Semester {
  id             Int          @id @default(autoincrement())
  deptId         Int
  academicYearId Int
  semNumber      Int
  yearOfStudy    Int
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  department     Department   @relation(fields: [deptId], references: [id], onDelete: Cascade)
  students       Student[]
  subjects       Subject[]

  @@unique([deptId, semNumber, academicYearId])
  @@map("semesters")
}

model Subject {
  id         Int          @id @default(autoincrement())
  deptId     Int
  semId      Int
  code       String
  name       String
  credits    Int          @default(4)
  teacherId  Int?
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  attendance Attendance[]
  department Department   @relation(fields: [deptId], references: [id], onDelete: Cascade)
  semester   Semester     @relation(fields: [semId], references: [id], onDelete: Cascade)
  teacher    User?        @relation(fields: [teacherId], references: [id])

  @@unique([deptId, semId, code])
  @@map("subjects")
}

model Student {
  id            Int          @id @default(autoincrement())
  deptId        Int
  semId         Int
  rollNo        String
  examRoll      String
  name          String
  phone         String?
  email         String?
  guardianName  String?
  guardianPhone String?
  address       String?
  dateOfBirth   DateTime?
  gender        Gender?
  yearOfStudy   Int
  isActive      Boolean      @default(true)
  enrolledAt    DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  attendance    Attendance[]
  department    Department   @relation(fields: [deptId], references: [id], onDelete: Cascade)
  semester      Semester     @relation(fields: [semId], references: [id])

  @@unique([deptId, rollNo])
  @@unique([deptId, examRoll])
  @@map("students")
}

model Attendance {
  id         Int              @id @default(autoincrement())
  studentId  Int
  subjectId  Int
  date       DateTime
  status     AttendanceStatus
  markedById Int
  source     AttendanceSource @default(MANUAL)
  isLocked   Boolean          @default(false)
  remarks    String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  markedBy   User             @relation(fields: [markedById], references: [id])
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, date])
  @@map("attendance")
}

model Holiday {
  id         Int         @id @default(autoincrement())
  deptId     Int?
  date       DateTime
  reason     String
  isGlobal   Boolean     @default(false)
  createdAt  DateTime    @default(now())
  department Department? @relation(fields: [deptId], references: [id], onDelete: Cascade)

  @@map("holidays")
}

model Setting {
  id     Int          @id @default(autoincrement())
  key    String
  value  String
  scope  SettingScope @default(GLOBAL)
  deptId Int?

  @@unique([key, scope, deptId])
  @@map("settings")
}

model AiLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  inputText    String
  parsedOutput String?
  actionTaken  String?
  success      Boolean  @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_logs")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum UserRole {
  SUPER_ADMIN
  HOD
  TEACHER
}

enum ProgrammeType {
  UG
  PG
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

enum AttendanceSource {
  MANUAL
  AI
  IMPORT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SettingScope {
  GLOBAL
  DEPARTMENT
}

enum NotificationType {
  SHORTAGE_ALERT
  ATTENDANCE_LOCKED
  SYSTEM
  HOLIDAY
  ANNOUNCEMENT
}
